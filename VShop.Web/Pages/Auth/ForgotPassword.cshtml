@page
@model VShop.Web.Pages.Auth.ForgotPasswordModel
@{
    Layout = "_LayoutClient";
    ViewData["Title"] = "Recuperar Contraseña";
}

<div class="container py-5" style="max-width: 440px;">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <h5 class="card-title text-center mb-4 fw-bold">Recuperar Contraseña</h5>

            @if (Model.Sent)
            {
                <div class="alert alert-success text-center">
                    <i class="fas fa-envelope-circle-check fa-2x mb-2 d-block"></i>
                    Si el correo existe en nuestro sistema recibirás un enlace para restablecer tu contraseña.
                </div>
                <div class="text-center mt-3">
                    <a asp-page="/Auth/Login" class="btn btn-outline-secondary btn-sm">
                        <i class="fas fa-arrow-left me-1"></i>Volver al login
                    </a>
                </div>
            }
            else
            {
                <p class="text-muted small text-center mb-4">
                    Ingresa tu correo electrónico y te enviaremos un enlace para restablecer tu contraseña.
                </p>

                @if (Model.Error != null)
                {
                    <div class="alert alert-danger">@Model.Error</div>
                }

                <form method="post">
                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label fw-semibold">Correo electrónico</label>
                        <input asp-for="Input.Email" class="form-control" type="email"
                               placeholder="correo@ejemplo.com" autofocus required />
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>
                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-vshop py-2">
                            <i class="fas fa-paper-plane me-1"></i>Enviar enlace
                        </button>
                    </div>
                </form>

                <div class="text-center mt-3 small">
                    <a asp-page="/Auth/Login" class="text-decoration-none">Volver al login</a>
                </div>
            }
        </div>
    </div>
</div>
