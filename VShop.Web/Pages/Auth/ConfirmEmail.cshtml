@page
@model VShop.Web.Pages.Auth.ConfirmEmailModel
@{
    Layout = "_LayoutClient";
    ViewData["Title"] = "Confirmar Correo";
}

<div class="container py-5" style="max-width: 480px;">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4 text-center">
            @if (Model.Success)
            {
                <i class="fas fa-circle-check fa-4x text-success mb-3"></i>
                <h5 class="fw-bold mb-2">¡Correo confirmado!</h5>
                <p class="text-muted">@Model.Message</p>
                <a asp-page="/Auth/Login" class="btn btn-vshop mt-2">
                    <i class="fas fa-sign-in-alt me-1"></i>Iniciar sesión
                </a>
            }
            else
            {
                <i class="fas fa-circle-xmark fa-4x text-danger mb-3"></i>
                <h5 class="fw-bold mb-2">Error de confirmación</h5>
                <p class="text-muted">@Model.Message</p>
                <a asp-page="/Auth/Login" class="btn btn-outline-secondary mt-2">
                    <i class="fas fa-arrow-left me-1"></i>Volver al login
                </a>
            }
        </div>
    </div>
</div>
