@page
@model VShop.Web.Pages.Auth.ResetPasswordModel
@{
    Layout = "_LayoutClient";
    ViewData["Title"] = "Restablecer Contraseña";
}

<div class="container py-5" style="max-width: 460px;">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <h5 class="card-title text-center mb-4 fw-bold">Nueva Contraseña</h5>

            @if (Model.Success)
            {
                <div class="alert alert-success text-center">
                    <i class="fas fa-circle-check fa-2x mb-2 d-block"></i>
                    Tu contraseña fue actualizada correctamente.
                </div>
                <div class="d-grid mt-3">
                    <a asp-page="/Auth/Login" class="btn btn-vshop py-2">
                        <i class="fas fa-sign-in-alt me-1"></i>Iniciar sesión
                    </a>
                </div>
            }
            else
            {
                @if (Model.Errors.Count > 0)
                {
                    <div class="alert alert-danger">
                        <ul class="mb-0">
                            @foreach (var e in Model.Errors)
                            {
                                <li>@e</li>
                            }
                        </ul>
                    </div>
                }

                <form method="post">
                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="Token" />

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label fw-semibold">Nueva contraseña</label>
                        <input asp-for="Input.Password" class="form-control" type="password"
                               placeholder="Mínimo 8 caracteres" autofocus required />
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold">Confirmar contraseña</label>
                        <input asp-for="Input.ConfirmPassword" class="form-control" type="password"
                               placeholder="Repetir contraseña" required />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>
                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-vshop py-2">
                            <i class="fas fa-key me-1"></i>Restablecer contraseña
                        </button>
                    </div>
                </form>
            }
        </div>
    </div>
</div>
