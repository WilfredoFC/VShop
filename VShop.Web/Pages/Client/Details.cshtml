@page "{id:int}"
@model VShop.Web.Pages.Client.DetailsModel
@{
    Layout = "_LayoutClient";
    ViewData["Title"] = Model.Producto?.Nombre ?? "Detalle";
}

@if (Model.Producto == null)
{
    <div class="container py-5 text-center">
        <h3>Producto no encontrado.</h3>
        <a asp-page="/Client/Index" class="btn btn-vshop mt-3">Volver al catálogo</a>
    </div>
    return;
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Client/Index">Catálogo</a></li>
            <li class="breadcrumb-item active">@Model.Producto.Nombre</li>
        </ol>
    </nav>

    <div class="row g-4">
        <!-- Imagen -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-3 text-center">
                    @{
                        var principal = Model.Producto.Imagenes.FirstOrDefault(i => i.EsPrincipal)
                                     ?? Model.Producto.Imagenes.FirstOrDefault();
                    }
                    @if (principal != null)
                    {
                        <img id="mainImage" src="@Model.ApiBase/imagenes/@principal.Id"
                             class="img-fluid rounded" style="max-height:400px;object-fit:contain;"
                             alt="@Model.Producto.Nombre">
                    }
                    else
                    {
                        <div class="py-5 text-muted"><i class="fas fa-image fa-5x mb-3"></i><p>Imagen no disponible</p></div>
                    }

                    @if (Model.Producto.Imagenes.Count > 1)
                    {
                        <div class="d-flex flex-wrap gap-2 mt-3 justify-content-center">
                            @foreach (var img in Model.Producto.Imagenes)
                            {
                                <img src="@Model.ApiBase/imagenes/@img.Id"
                                     class="img-thumbnail thumbnail-link @(img.EsPrincipal ? "border-primary" : "")"
                                     style="height:70px;width:70px;object-fit:cover;cursor:pointer;"
                                     onclick="document.getElementById('mainImage').src=this.src"
                                     alt="Miniatura">
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Info -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="mb-2">
                        @if (Model.Producto.TieneDescuento)
                        {
                            <span class="badge bg-danger me-1">Oferta</span>
                        }
                        <span class="badge bg-light text-dark">@Model.Producto.Categoria</span>
                        <span class="badge bg-light text-dark ms-1">@Model.Producto.Marca</span>
                    </div>

                    <h1 class="h3 mb-3">@Model.Producto.Nombre</h1>

                    <div class="bg-light rounded p-3 mb-3">
                        @if (Model.Producto.TieneDescuento && Model.Producto.PrecioDescuento.HasValue)
                        {
                            <div class="text-muted text-decoration-line-through">@Model.Producto.Precio.ToString("C")</div>
                            <div class="fs-2 fw-bold text-danger">@Model.Producto.PrecioFinal.ToString("C")</div>
                            <small class="text-success">
                                Ahorras @((Model.Producto.Precio - Model.Producto.PrecioFinal).ToString("C"))
                            </small>
                        }
                        else
                        {
                            <div class="fs-2 fw-bold">@Model.Producto.Precio.ToString("C")</div>
                        }
                    </div>

                    <p class="text-muted">@Model.Producto.Descripcion</p>

                    <div class="mb-3">
                        @if (Model.Producto.Stock > 0)
                        {
                            <span class="text-success"><i class="fas fa-check-circle me-1"></i>@Model.Producto.Stock unidades disponibles</span>
                        }
                        else
                        {
                            <span class="text-danger"><i class="fas fa-times-circle me-1"></i>Agotado</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Relacionados -->
    @if (Model.Relacionados.Any())
    {
        <div class="mt-5">
            <h4 class="mb-3">Productos Relacionados</h4>
            <div class="row row-cols-2 row-cols-md-4 g-3">
                @foreach (var r in Model.Relacionados)
                {
                    <div class="col">
                        <div class="card border-0 shadow-sm h-100">
                            @if (r.ImagenPrincipalId.HasValue)
                            {
                                <img src="@Model.ApiBase/imagenes/@r.ImagenPrincipalId"
                                     class="card-img-top" style="height:150px;object-fit:cover;" alt="@r.Nombre">
                            }
                            <div class="card-body">
                                <h6><a asp-page="/Client/Details" asp-route-id="@r.Id" class="text-decoration-none text-dark stretched-link">@r.Nombre</a></h6>
                                <span class="fw-bold small">@r.PrecioFinal.ToString("C")</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
