@page
@model VShop.Web.Pages.Admin.Categorias.IndexModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Categorías";
}

<div class="container-fluid" style="max-width:900px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold"><i class="fas fa-tags me-2"></i>Categorías</h4>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalCategoria" onclick="prepareCreate()">
            <i class="fas fa-plus me-1"></i>Nueva
        </button>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th>Nombre</th><th>Descripción</th><th>Tipo</th><th class="text-center">Estado</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Categorias)
                    {
                        <tr>
                            <td class="fw-semibold">@c.Nombre</td>
                            <td class="text-muted small">@c.Descripcion</td>
                            <td>@c.Tipo</td>
                            <td class="text-center">
                                <span class="badge @(c.EsActivo ? "bg-success" : "bg-secondary")">
                                    @(c.EsActivo ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary me-1"
                                        onclick="prepareEdit(@c.Id, '@c.Nombre.Replace("'","\\'")', '@c.Descripcion.Replace("'","\\'")', '@c.Tipo')">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <form method="post" asp-page-handler="Delete" class="d-inline">
                                    <input type="hidden" name="id" value="@c.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('¿Eliminar @c.Nombre?')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="modalCategoria" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Categoría</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" id="categoriaForm">
                <div class="modal-body">
                    <input type="hidden" name="id" id="categoriaId" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nombre *</label>
                        <input type="text" name="nombre" class="form-control" id="categoriaNombre" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Descripción</label>
                        <input type="text" name="descripcion" class="form-control" id="categoriaDesc" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tipo</label>
                        <select name="tipo" class="form-select" id="categoriaTipo">
                            <option value="Personal">Personal</option>
                            <option value="Hogar">Hogar</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function prepareCreate() {
            document.getElementById('modalTitle').textContent = 'Nueva Categoría';
            document.getElementById('categoriaForm').action = '@Url.Page("Index", "Create")';
            document.getElementById('categoriaId').value = '';
            document.getElementById('categoriaNombre').value = '';
            document.getElementById('categoriaDesc').value = '';
        }
        function prepareEdit(id, nombre, desc, tipo) {
            document.getElementById('modalTitle').textContent = 'Editar Categoría';
            document.getElementById('categoriaForm').action = '@Url.Page("Index", "Edit")';
            document.getElementById('categoriaId').value = id;
            document.getElementById('categoriaNombre').value = nombre;
            document.getElementById('categoriaDesc').value = desc;
            document.getElementById('categoriaTipo').value = tipo;
            new bootstrap.Modal(document.getElementById('modalCategoria')).show();
        }
    </script>
}
