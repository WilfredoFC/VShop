@page
@model VShop.Web.Pages.Admin.Productos.CreateModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Nuevo Producto";
}

<div class="container-fluid" style="max-width:800px;">
    <div class="d-flex align-items-center mb-4 gap-3">
        <a asp-page="/Admin/Productos/Index" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-left"></i>
        </a>
        <h4 class="fw-bold mb-0">Nuevo Producto</h4>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <form method="post" enctype="multipart/form-data">
                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="form-label fw-semibold">Nombre *</label>
                        <input asp-for="Input.Nombre" class="form-control" required />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">SKU *</label>
                        <input asp-for="Input.SKU" class="form-control" required />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Descripción *</label>
                        <textarea asp-for="Input.Descripcion" class="form-control" rows="3" required></textarea>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Precio *</label>
                        <input asp-for="Input.Precio" class="form-control" type="number" step="0.01" required />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Precio con Descuento</label>
                        <input asp-for="Input.PrecioDescuento" class="form-control" type="number" step="0.01" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Stock *</label>
                        <input asp-for="Input.Stock" class="form-control" type="number" required />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Stock Mínimo</label>
                        <input asp-for="Input.StockMinimo" class="form-control" type="number" value="10" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Categoría *</label>
                        <select asp-for="Input.CategoriaId" class="form-select" required>
                            <option value="">Seleccionar...</option>
                            @foreach (var c in Model.Categorias)
                            {
                                <option value="@c.Id">@c.Nombre</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Marca</label>
                        <select asp-for="Input.MarcaId" class="form-select">
                            <option value="">Sin marca</option>
                            @foreach (var m in Model.Marcas)
                            {
                                <option value="@m.Id">@m.Nombre</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <div class="form-check">
                            <input asp-for="Input.EsActivo" class="form-check-input" type="checkbox" checked />
                            <label class="form-check-label">Activo</label>
                        </div>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Imágenes</label>
                        <input type="file" name="Imagenes" class="form-control" multiple accept="image/*" />
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="fas fa-save me-1"></i>Guardar
                    </button>
                    <a asp-page="/Admin/Productos/Index" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>
