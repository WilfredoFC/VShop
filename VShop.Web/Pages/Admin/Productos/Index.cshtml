@page
@model VShop.Web.Pages.Admin.Productos.IndexModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Productos";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold"><i class="fas fa-box me-2"></i>Productos</h4>
        <a asp-page="/Admin/Productos/Create" class="btn btn-primary">
            <i class="fas fa-plus me-1"></i>Nuevo Producto
        </a>
    </div>

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body py-2">
            <form method="get" class="row g-2 align-items-center">
                <div class="col-md-6">
                    <input type="text" class="form-control" name="busqueda" value="@Model.Busqueda" placeholder="Buscar por nombre o SKU...">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-outline-primary w-100"><i class="fas fa-search me-1"></i>Buscar</button>
                </div>
                <div class="col-md-2">
                    <a asp-page="/Admin/Productos/Index" class="btn btn-outline-secondary w-100">Limpiar</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th width="60">Img</th>
                            <th>Nombre</th>
                            <th>SKU</th>
                            <th>Categoría</th>
                            <th class="text-end">Precio</th>
                            <th class="text-center">Stock</th>
                            <th class="text-center">Estado</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.Productos)
                        {
                            <tr>
                                <td>
                                    @if (p.ImagenPrincipalId.HasValue)
                                    {
                                        <img src="@Model.ApiBase/imagenes/@p.ImagenPrincipalId"
                                             class="img-thumbnail" width="50" height="50" style="object-fit:cover;">
                                    }
                                    else
                                    {
                                        <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width:50px;height:50px;">
                                            <i class="fas fa-image text-muted small"></i>
                                        </div>
                                    }
                                </td>
                                <td class="fw-semibold">@p.Nombre</td>
                                <td><small class="text-muted">@p.SKU</small></td>
                                <td>@p.Categoria</td>
                                <td class="text-end">
                                    @if (p.TieneDescuento)
                                    {
                                        <span class="text-muted text-decoration-line-through small">@p.Precio.ToString("C")</span><br>
                                        <span class="text-danger fw-semibold">@p.PrecioFinal.ToString("C")</span>
                                    }
                                    else
                                    {
                                        @p.Precio.ToString("C")
                                    }
                                </td>
                                <td class="text-center">
                                    <span class="badge @(p.Stock > 0 ? "bg-success" : "bg-danger")">@p.Stock</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge @(p.EsActivo ? "bg-success" : "bg-secondary")">
                                        @(p.EsActivo ? "Activo" : "Inactivo")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <a asp-page="/Admin/Productos/Edit" asp-route-id="@p.Id"
                                       class="btn btn-sm btn-outline-primary me-1">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button class="btn btn-sm btn-outline-danger"
                                            onclick="confirmDelete(@p.Id, '@p.Nombre')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                        @if (!Model.Productos.Any())
                        {
                            <tr><td colspan="8" class="text-center py-4 text-muted">Sin productos.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Paginación -->
    @if (Model.TotalPaginas > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= Model.TotalPaginas; i++)
                {
                    <li class="page-item @(i == Model.PaginaActual ? "active" : "")">
                        <a class="page-link" asp-page="/Admin/Productos/Index" asp-route-pagina="@i" asp-route-busqueda="@Model.Busqueda">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

<!-- Delete modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirmar eliminación</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                ¿Eliminar <strong id="deleteProductName"></strong>?
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancelar</button>
                <form method="post" asp-page-handler="Delete">
                    <input type="hidden" name="id" id="deleteProductId" />
                    <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(id, name) {
            document.getElementById('deleteProductId').value = id;
            document.getElementById('deleteProductName').textContent = name;
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }
    </script>
}
