@page "{id:int}"
@model VShop.Web.Pages.Admin.Productos.EditModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Editar Producto";
}

<div class="container-fluid" style="max-width:900px;">
    <div class="d-flex align-items-center mb-4 gap-3">
        <a asp-page="/Admin/Productos/Index" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-left"></i>
        </a>
        <h4 class="fw-bold mb-0">Editar Producto</h4>
    </div>

    <div class="row g-4">
        <!-- Formulario -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <form method="post">
                        <div class="row g-3">
                            <div class="col-md-8">
                                <label class="form-label fw-semibold">Nombre *</label>
                                <input asp-for="Input.Nombre" class="form-control" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">SKU</label>
                                <input asp-for="Input.SKU" class="form-control" />
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">Descripción</label>
                                <textarea asp-for="Input.Descripcion" class="form-control" rows="3"></textarea>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Precio *</label>
                                <input asp-for="Input.Precio" class="form-control" type="number" step="0.01" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Precio con Descuento</label>
                                <input asp-for="Input.PrecioDescuento" class="form-control" type="number" step="0.01" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Stock</label>
                                <input asp-for="Input.Stock" class="form-control" type="number" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Stock Mínimo</label>
                                <input asp-for="Input.StockMinimo" class="form-control" type="number" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Categoría</label>
                                <select asp-for="Input.CategoriaId" class="form-select">
                                    @foreach (var c in Model.Categorias)
                                    {
                                        <option value="@c.Id">@c.Nombre</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Marca</label>
                                <select asp-for="Input.MarcaId" class="form-select">
                                    <option value="">Sin marca</option>
                                    @foreach (var m in Model.Marcas)
                                    {
                                        <option value="@m.Id">@m.Nombre</option>
                                    }
                                </select>
                            </div>
                            <div class="col-12">
                                <div class="form-check">
                                    <input asp-for="Input.EsActivo" class="form-check-input" type="checkbox" />
                                    <label class="form-check-label">Activo</label>
                                </div>
                            </div>
                        </div>
                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="fas fa-save me-1"></i>Guardar
                            </button>
                            <a asp-page="/Admin/Productos/Index" class="btn btn-outline-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Imágenes -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">Imágenes</div>
                <div class="card-body">
                    @if (Model.Imagenes.Any())
                    {
                        <div class="row g-2 mb-3">
                            @foreach (var img in Model.Imagenes)
                            {
                                <div class="col-6 position-relative">
                                    <img src="@Model.ApiBase/imagenes/@img.Id"
                                         class="img-thumbnail w-100 @(img.EsPrincipal ? "border-primary" : "")"
                                         style="height:90px;object-fit:cover;">
                                    @if (img.EsPrincipal)
                                    {
                                        <span class="position-absolute top-0 start-0 badge bg-primary m-1 small">Principal</span>
                                    }
                                    <div class="d-flex gap-1 mt-1">
                                        @if (!img.EsPrincipal)
                                        {
                                            <form method="post" asp-page-handler="SetPrincipal" class="flex-fill">
                                                <input type="hidden" name="imagenId" value="@img.Id" />
                                                <button class="btn btn-outline-primary btn-sm w-100" title="Hacer principal">
                                                    <i class="fas fa-star small"></i>
                                                </button>
                                            </form>
                                        }
                                        <form method="post" asp-page-handler="DeleteImagen" class="flex-fill">
                                            <input type="hidden" name="imagenId" value="@img.Id" />
                                            <button class="btn btn-outline-danger btn-sm w-100">
                                                <i class="fas fa-trash small"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    <form method="post" enctype="multipart/form-data" asp-page-handler="SubirImagenes">
                        <input type="file" name="Imagenes" class="form-control form-control-sm mb-2" multiple accept="image/*" />
                        <button type="submit" class="btn btn-outline-primary btn-sm w-100">
                            <i class="fas fa-upload me-1"></i>Subir
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
