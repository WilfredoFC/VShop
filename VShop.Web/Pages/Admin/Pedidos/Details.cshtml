@page "{id:int}"
@model VShop.Web.Pages.Admin.Pedidos.DetailsModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Detalle Pedido";
}

@if (Model.Pedido == null)
{
    <p>Pedido no encontrado.</p>
    return;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold">Pedido #@Model.Pedido.NumeroPedido</h4>
        <a asp-page="/Admin/Pedidos/Index" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-left me-1"></i>Volver
        </a>
    </div>

    <div class="row g-4">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white fw-semibold">Productos</div>
                <div class="card-body p-0">
                    <table class="table mb-0">
                        <thead class="table-light">
                            <tr><th>Producto</th><th class="text-center">Cant.</th><th class="text-end">Precio</th><th class="text-end">Subtotal</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var d in Model.Pedido.Detalles)
                            {
                                <tr>
                                    <td>@d.NombreProducto</td>
                                    <td class="text-center">@d.Cantidad</td>
                                    <td class="text-end">@d.PrecioUnitario.ToString("C")</td>
                                    <td class="text-end fw-semibold">@d.Subtotal.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr><td colspan="3" class="text-end">Subtotal</td><td class="text-end">@Model.Pedido.Subtotal.ToString("C")</td></tr>
                            <tr><td colspan="3" class="text-end">Impuestos (18%)</td><td class="text-end">@Model.Pedido.Impuestos.ToString("C")</td></tr>
                            <tr class="fw-bold"><td colspan="3" class="text-end">Total</td><td class="text-end">@Model.Pedido.Total.ToString("C")</td></tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-white fw-semibold">Actualizar Estado</div>
                <div class="card-body">
                    <form method="post" asp-page-handler="ActualizarEstado">
                        <input type="hidden" name="id" value="@Model.Pedido.Id" />
                        <select name="estado" class="form-select mb-2">
                            @foreach (var e in new[] { "Pendiente", "Confirmado", "EnProceso", "Enviado", "Entregado", "Cancelado" })
                            {
                                <option value="@e" selected="@(Model.Pedido.Estado == e)">@e</option>
                            }
                        </select>
                        <button type="submit" class="btn btn-primary w-100">Guardar</button>
                    </form>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">Información de Envío</div>
                <div class="card-body small">
                    <p class="mb-1"><strong>Dirección:</strong> @Model.Pedido.DireccionEnvio</p>
                    <p class="mb-1"><strong>Ciudad:</strong> @Model.Pedido.Ciudad</p>
                    <p class="mb-1"><strong>Teléfono:</strong> @Model.Pedido.TelefonoContacto</p>
                    <p class="mb-1"><strong>Método de pago:</strong> @Model.Pedido.MetodoPago</p>
                    @if (!string.IsNullOrWhiteSpace(Model.Pedido.Notas))
                    {
                        <p class="mb-0"><strong>Notas:</strong> @Model.Pedido.Notas</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
