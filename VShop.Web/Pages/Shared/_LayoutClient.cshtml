<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VShop</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        :root { --primary: #667eea; --secondary: #764ba2; }
        .btn-vshop { background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); color: white; border: none; }
        .btn-vshop:hover { opacity: 0.9; color: white; }
        .text-vshop { color: var(--primary); }
    </style>
</head>
<body class="bg-light">
    <header class="sticky-top bg-white shadow-sm">
        <nav class="navbar navbar-expand-lg navbar-light py-2">
            <div class="container">
                <a class="navbar-brand fw-bold fs-3" asp-page="/Client/Index">
                    <span style="color: var(--primary)">V</span>Shop
                </a>
                <form asp-page="/Client/Index" method="get" class="d-none d-lg-flex flex-grow-1 mx-4">
                    <div class="input-group">
                        <input type="text" class="form-control" name="busqueda"
                               value="@Context.Request.Query["busqueda"]" placeholder="Buscar productos...">
                        <button class="btn btn-vshop" type="submit"><i class="fas fa-search"></i></button>
                    </div>
                </form>
                <div class="d-flex align-items-center gap-2">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a class="btn btn-outline-secondary btn-sm position-relative" asp-page="/Carrito/Index" title="Mi carrito">
                            <i class="fas fa-cart-shopping"></i>
                        </a>
                        <span class="d-none d-md-inline text-muted small">
                            Hola, @User.FindFirst("firstName")?.Value
                        </span>
                        <a class="btn btn-outline-secondary btn-sm" asp-page="/Auth/Logout" title="Cerrar sesión">
                            <i class="fas fa-sign-out-alt"></i>
                        </a>
                    }
                    else
                    {
                        <a class="btn btn-vshop btn-sm" asp-page="/Auth/Login">
                            <i class="fas fa-user me-1"></i>Entrar
                        </a>
                    }
                </div>
            </div>
        </nav>
    </header>

    <main>
        @if (TempData["Success"] != null)
        {
            <div class="container mt-2">
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="container mt-2">
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="bg-dark text-white py-4 mt-5">
        <div class="container text-center">
            <p class="mb-0">&copy; @DateTime.Now.Year VShop. Todos los derechos reservados.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.0/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
