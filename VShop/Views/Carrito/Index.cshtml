@model List<VShop.Application.Dtos.CarritoItem.CarritoItemDto>

@{
    ViewData["Title"] = "Mi Carrito";
}

<div class="container mt-4">
    <h1>Mi Carrito de Compras</h1>

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info mt-4">
            <p>Tu carrito está vacío.</p>
            <a href="/Productos" class="btn btn-primary">Continuar Comprando</a>
        </div>
    }
    else
    {
        <div class="table-responsive mt-4">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Producto</th>
                        <th>Precio Unitario</th>
                        <th>Cantidad</th>
                        <th>Subtotal</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@item.Producto?.Nombre ?? "Producto"</strong>
                            </td>
                            <td>RD$@item.Producto?.Precio.ToString("F2")</td>
                            <td>
                                <input type="number" class="form-control cantidad" style="width: 80px;" 
                                       value="@item.Cantidad" min="1" 
                                       data-item-id="@item.Id" 
                                       data-stock="@item.Producto?.Stock" />
                            </td>
                            <td>RD$@(item.Producto != null ? (item.Producto.Precio * item.Cantidad).ToString("F2") : "0.00")</td>
                            <td>
                                <button class="btn btn-sm btn-danger eliminar-item" data-item-id="@item.Id">
                                    <i class="fas fa-trash"></i> Eliminar
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="row mt-4">
            <div class="col-md-8">
                <a href="/Productos" class="btn btn-outline-primary">
                    <i class="fas fa-arrow-left"></i> Continuar Comprando
                </a>
                <button class="btn btn-outline-danger" id="vaciarCarrito">
                    <i class="fas fa-trash"></i> Vaciar Carrito
                </button>
            </div>
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Resumen de Compra</h5>
                        <hr />
                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal:</span>
                            <span id="subtotal">RD$0.00</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span>ITBIS (18%):</span>
                            <span id="impuestos">RD$0.00</span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between" style="font-size: 1.2em; font-weight: bold;">
                            <span>Total:</span>
                            <span id="total">RD$0.00</span>
                        </div>
                        @* DESHABILITADO: Botón de pago - Sistema temporalmente deshabilitado
                        <button class="btn btn-success w-100 mt-3" id="procederPago">
                            <i class="fas fa-credit-card"></i> Proceder al Pago
                        </button>
                        *@
                        <button class="btn btn-warning w-100 mt-3" disabled title="Sistema de pagos temporalmente deshabilitado">
                            <i class="fas fa-lock"></i> Pagos Deshabilitados
                        </button>
                        <small class="d-block text-center mt-2 text-muted">Sistema de pagos en configuración</small>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function actualizarTotales() {
            $.ajax({
                url: '/Carrito/ObtenerCarrito',
                type: 'GET',
                success: function (data) {
                    if (data.success) {
                        $('#subtotal').text('RD$' + data.subtotal.toFixed(2));
                        $('#impuestos').text('RD$' + data.impuestos.toFixed(2));
                        $('#total').text('RD$' + data.total.toFixed(2));
                    }
                },
                error: function () {
                    alert('Error al obtener el carrito');
                }
            });
        }

        $('.cantidad').change(function () {
            const itemId = $(this).data('item-id');
            const nuevaCantidad = parseInt($(this).val());
            const stock = $(this).data('stock');

            if (nuevaCantidad <= 0) {
                $(this).val(1);
                return;
            }

            if (nuevaCantidad > stock) {
                alert('Stock insuficiente. Disponible: ' + stock);
                $(this).val(1);
                return;
            }

            $.ajax({
                url: '/Carrito/ActualizarCantidad',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    carritoItemId: itemId,
                    nuevaCantidad: nuevaCantidad
                }),
                success: function (data) {
                    if (data.success) {
                        actualizarTotales();
                        location.reload();
                    } else {
                        alert(data.message);
                    }
                },
                error: function () {
                    alert('Error al actualizar la cantidad');
                }
            });
        });

        $('.eliminar-item').click(function () {
            if (!confirm('¿Deseas eliminar este producto del carrito?')) return;

            const itemId = $(this).data('item-id');
            $.ajax({
                url: '/Carrito/EliminarProducto',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ carritoItemId: itemId }),
                success: function (data) {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert(data.message);
                    }
                },
                error: function () {
                    alert('Error al eliminar el producto');
                }
            });
        });

        $('#vaciarCarrito').click(function () {
            if (!confirm('¿Deseas vaciar todo el carrito?')) return;

            $.ajax({
                url: '/Carrito/VaciarCarrito',
                type: 'POST',
                success: function (data) {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert(data.message);
                    }
                },
                error: function () {
                    alert('Error al vaciar el carrito');
                }
            });
        });

        // DESHABILITADO: Manejo de pago - Sistema temporalmente deshabilitado
        // $('#procederPago').click(function () {
        //     // Redirigir a formulario de checkout
        //     window.location.href = '/Pago/Checkout';
        // });

        // Actualizar totales al cargar la página
        $(document).ready(function () {
            actualizarTotales();
        });
    </script>
}
