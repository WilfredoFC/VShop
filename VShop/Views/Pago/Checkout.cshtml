@model VShop.Models.IniciarPagoRequestViewModel

@{
    ViewData["Title"] = "Checkout - Completar Pedido";
}

<div class="container mt-5">
    <div class="alert alert-warning" role="alert">
        <h4 class="alert-heading">
            <i class="fas fa-lock"></i> Sistema de Pagos Temporalmente Deshabilitado
        </h4>
        <p>
            El sistema de pagos a través de Azul está temporalmente deshabilitado mientras se configuran las credenciales necesarias.
        </p>
        <hr>
        <p class="mb-0">
            Por favor, <a href="/Home/Contacto" class="alert-link">contáctanos</a> para realizar tu pedido o regresa al <a href="/Productos" class="alert-link">catálogo de productos</a>.
        </p>
    </div>

    <div class="row justify-content-center mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body text-center">
                    <i class="fas fa-exclamation-circle" style="font-size: 3rem; color: #ff9800;"></i>
                    <h5 class="card-title mt-3">Pagos Deshabilitados</h5>
                    <p class="card-text">
                        Actualmente no puedes completar compras porque el sistema de pagos está siendo configurado.
                    </p>
                    <a href="/Productos" class="btn btn-primary mt-3">
                        <i class="fas fa-arrow-left"></i> Volver al Catálogo
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Los scripts de pago están deshabilitados
        // Descomentar cuando el sistema de pagos esté disponible
    </script>
}

@* ========== VISTA ORIGINAL COMENTADA - DESHABILITADA ==========
@{
    // DESHABILITADA: Vista de Checkout con formulario de pago Azul
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="MetodoPago" id="azul" 
                                   value="Azul" checked />
                            <label class="form-check-label" for="azul">
                                <strong>Azul - Tarjeta de Crédito/Débito</strong>
                                <small class="d-block text-muted">Pago seguro mediante Azul</small>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card sticky-top">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">Resumen del Pedido</h5>
                    </div>
                    <div class="card-body">
                        <div id="resumenCarrito">
                            <p class="text-center text-muted">Cargando resumen...</p>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal:</span>
                            <span id="resumoSubtotal">RD$0.00</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span>ITBIS (18%):</span>
                            <span id="resumoImpuestos">RD$0.00</span>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between" style="font-size: 1.3em; font-weight: bold;">
                            <span>Total a Pagar:</span>
                            <span id="resumoTotal">RD$0.00</span>
                        </div>

                        <button type="button" class="btn btn-primary w-100 mt-4" id="btnProcesarPago">
                            <i class="fas fa-lock"></i> Procesar Pago Seguro
                        </button>

                        <small class="d-block text-center mt-2 text-muted">
                            <i class="fas fa-shield-alt"></i> Tu información está protegida
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- Modal de carga -->
<div class="modal fade" id="modalCarga" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center">
                <div class="spinner-border text-primary mb-3" role="status">
                    <span class="visually-hidden">Cargando...</span>
                </div>
                <p>Procesando tu pago. Por favor espera...</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Obtener resumen del carrito
        function cargarResumen() {
            $.ajax({
                url: '/Carrito/ObtenerCarrito',
                type: 'GET',
                success: function (data) {
                    if (data.success) {
                        let html = '<h6>Productos:</h6><ul class="list-unstyled">';
                        data.items.forEach(function (item) {
                            html += '<li class="d-flex justify-content-between"><span>' + item.producto.nombre + ' (x' + item.cantidad + ')</span><span>RD$' + (item.producto.precio * item.cantidad).toFixed(2) + '</span></li>';
                        });
                        html += '</ul>';
                        $('#resumenCarrito').html(html);
                        
                        $('#resumoSubtotal').text('RD$' + data.subtotal.toFixed(2));
                        $('#resumoImpuestos').text('RD$' + data.impuestos.toFixed(2));
                        $('#resumoTotal').text('RD$' + data.total.toFixed(2));
                    }
                },
                error: function () {
                    $('#resumenCarrito').html('<p class="text-danger">Error al cargar el resumen</p>');
                }
            });
        }

        // Procesar pago
        $('#btnProcesarPago').click(function () {
            // Validar formulario
            if (!$('#formularioPago')[0].checkValidity()) {
                alert('Por favor completa todos los campos requeridos');
                return;
            }

            // Mostrar modal de carga
            const modal = new bootstrap.Modal(document.getElementById('modalCarga'), {});
            modal.show();

            // Preparar datos
            const datos = {
                Direccion: $('#direccion').val(),
                Ciudad: $('#ciudad').val(),
                Telefono: $('#telefono').val(),
                Notas: $('#notas').val()
            };

            // Enviar solicitud al servidor
            $.ajax({
                url: '/Pago/Iniciar',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(datos),
                success: function (response) {
                    if (response.success && response.pagoUrl) {
                        // Redirigir a Azul
                        window.location.href = response.pagoUrl;
                    } else {
                        modal.hide();
                        alert('Error: ' + (response.message || 'No se pudo procesar el pago'));
                    }
                },
                error: function (xhr) {
                    modal.hide();
                    try {
                        const error = JSON.parse(xhr.responseText);
                        alert('Error: ' + (error.message || 'Error procesando el pago'));
                    } catch (e) {
                        alert('Error al procesar el pago');
                    }
                }
            });
        });

        // Cargar resumen al abrir la página
        $(document).ready(function () {
            cargarResumen();
        });
    </script>
}
*@
