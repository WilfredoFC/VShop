@model LoginViewModel
@{
    ViewData["Title"] = "Login Page";
    Layout = "_LayoutAnonymous";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col text-center">
            <h1 class="display-4">Inicio de Sesión</h1>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-12 col-md-6 col-lg-4">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0 text-center">Ingrese sus credenciales</h5>
                </div>
                <div class="card-body">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        @Html.ValidationSummary(false,"",new {@class = "alert alert-danger"})
                    }
                    
                    <form asp-controller="Login" asp-action="Index" method="POST">
                        <div class="mb-3">
                            <label asp-for="UserName" class="form-label">Usuario:</label>
                            <input class="form-control" asp-for="UserName" placeholder="Ingrese su nombre de usuario" />
                            <span asp-validation-for="UserName" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-4">
                            <label asp-for="Password" class="form-label">Contraseña:</label>
                            <input type="password" class="form-control" asp-for="Password" placeholder="Ingrese su contraseña" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                        
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-controller="Login" asp-action="ForgotPassword" class="btn btn-outline-warning me-md-2 btn-sm">
                                <i class="fa fa-question-circle me-1"></i>Olvidé contraseña
                            </a>

                            <a asp-controller="Login" asp-action="Register" class="btn btn-outline-primary me-md-2 btn-sm">
                                <i class="fa fa-user-plus me-1"></i>Crear cuenta
                            </a>

                            <button type="submit" class="btn btn-success btn-sm">
                                <i class="fa fa-sign-in me-1"></i>Ingresar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>