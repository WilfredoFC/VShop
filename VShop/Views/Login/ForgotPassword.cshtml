@model ForgotPasswordRequestViewModel
@{
    ViewData["Title"] = "Recuperar Contraseña";
    Layout = "_LayoutAnonymous";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col text-center">
            <h1 class="display-4">Recuperar Contraseña</h1>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-12 col-md-6 col-lg-4">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0 text-center">Ingrese su nombre de usuario</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.HasError != null && ViewBag.HasError)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @foreach (var error in ViewBag.Errors)
                            {
                                <p class="mb-1">@error</p>
                            }
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-controller="Login" asp-action="ForgotPassword" method="POST">
                        <div class="mb-4">
                            <label asp-for="UserName" class="form-label">Nombre de usuario:</label>
                            <input class="form-control" asp-for="UserName" placeholder="Ingrese su nombre de usuario" />
                            <span asp-validation-for="UserName" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-controller="Login" asp-action="Index" class="btn btn-outline-warning me-md-2">
                                <i class="fa fa-arrow-left me-2"></i>Volver al login
                            </a>

                            <button type="submit" class="btn btn-success">
                                <i class="fa fa-paper-plane me-2"></i>Enviar solicitud
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>