@model ProductoDetailsViewModel
@{
    ViewData["Title"] = "Detalles del Producto";
    ViewData["ActivePage"] = "Productos";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-action="Index" asp-controller="Productos">Productos</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">Detalles</li>
                </ol>
            </nav>

            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h3 mb-0">
                        <i class="fas fa-eye me-2"></i>@Model.Nombre
                    </h1>
                    <p class="text-muted mb-0">Información completa del producto</p>
                </div>
                <div>
                    <a asp-action="Index" class="btn btn-outline-secondary me-2">
                        <i class="fas fa-arrow-left me-1"></i>Volver
                    </a>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-vshop">
                        <i class="fas fa-edit me-1"></i>Editar Producto
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Columna izquierda: Galería de imágenes -->
        <div class="col-lg-5">
            <div class="card vshop-card mb-4">
                <div class="card-body">
                    @if (Model.Imagenes != null && Model.Imagenes.Any())
                    {
                        <!-- Imagen principal -->
                        <div class="text-center mb-4">
                            @{
                                var imagenPrincipal = Model.Imagenes.FirstOrDefault(i => i.EsPrincipal) ?? Model.Imagenes.First();
                            }
                            <img src="@Url.Content($"~/{imagenPrincipal.UrlImagen}")"
                                 class="img-fluid rounded"
                                 alt="@Model.Nombre"
                                 id="mainImage"
                                 style="max-height: 400px; object-fit: contain;">
                        </div>

                        <!-- Miniaturas -->
                        @if (Model.Imagenes.Count > 1)
                        {
                            <div class="row g-2">
                                @foreach (var imagen in Model.Imagenes)
                                {
                                    <div class="col-3">
                                        <img src="@Url.Content($"~/{imagen.UrlImagen}")"
                                             class="img-thumbnail @(imagen.EsPrincipal ? "border-primary" : "")"
                                             alt="Imagen @imagen.Orden"
                                             style="cursor: pointer; height: 80px; object-fit: cover;"
                                             onclick="changeMainImage('@Url.Content($"~/{imagen.UrlImagen}")', this)">
                                        @if (imagen.EsPrincipal)
                                        {
                                            <div class="text-center mt-1">
                                                <span class="badge bg-primary">Principal</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-image fa-5x text-muted mb-3"></i>
                            <h5 class="text-muted">No hay imágenes disponibles</h5>
                            <p class="text-muted">Este producto no tiene imágenes asociadas.</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Información rápida -->
            <div class="card vshop-card">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="fas fa-chart-bar me-2"></i>Resumen del Producto</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-6 mb-3">
                            <div class="text-center">
                                <div class="h2 mb-1 text-vshop-primary">@Model.Stock</div>
                                <small class="text-muted">Stock Actual</small>
                            </div>
                        </div>
                        <div class="col-6 mb-3">
                            <div class="text-center">
                                <div class="h2 mb-1 @(Model.Stock <= Model.StockMinimo ? "text-warning" : "text-success")">
                                    @Model.StockMinimo
                                </div>
                                <small class="text-muted">Stock Mínimo</small>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="progress mb-3" style="height: 10px;">
                                @{
                                    var porcentajeStock = Model.Stock > 100 ? 100 : Model.Stock;
                                }
                                <div class="progress-bar bg-@Model.EstadoStockClase"
                                     role="progressbar"
                                     style="width: @porcentajeStock%"
                                     aria-valuenow="@Model.Stock"
                                     aria-valuemin="0"
                                     aria-valuemax="100"></div>
                            </div>
                            <div class="text-center">
                                <span class="badge bg-@Model.EstadoStockClase">
                                    <i class="fas fa-box me-1"></i>@Model.EstadoStock
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Columna derecha: Información del producto -->
        <div class="col-lg-7">
            <!-- Información básica -->
            <div class="card vshop-card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Información del Producto</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted">Nombre del Producto</label>
                            <h5>@Model.Nombre</h5>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted">SKU</label>
                            <h5><code>@Model.SKU</code></h5>
                        </div>

                        <div class="col-12 mb-3">
                            <label class="form-label text-muted">Descripción</label>
                            <div class="border rounded p-3 bg-light">
                                @if (!string.IsNullOrEmpty(Model.Descripcion))
                                {
                                    @Html.Raw(Model.Descripcion.Replace("\n", "<br>"))
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">Sin descripción</span>
                                }
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted">Categoría</label>
                            <div>
                                <span class="badge bg-light text-dark">@Model.Categoria</span>
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted">Marca</label>
                            <div>
                                @if (!string.IsNullOrEmpty(Model.Marca))
                                {
                                    <span class="badge bg-light text-dark">@Model.Marca</span>
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">Sin marca</span>
                                }
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted">Estado</label>
                            <div>
                                @if (Model.EsActivo)
                                {
                                    <span class="badge bg-success">
                                        <i class="fas fa-check-circle me-1"></i>Activo
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        <i class="fas fa-times-circle me-1"></i>Inactivo
                                    </span>
                                }
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted">Fecha de Creación</label>
                            <div>@Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted">Última Actualización</label>
                            <div>@Model.FechaActualizacion.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Precios -->
            <div class="card vshop-card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="fas fa-tag me-2"></i>Precios</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted">Precio Regular</label>
                            <h4 class="text-vshop-primary">@Model.Precio.ToString("C")</h4>
                        </div>

                        @if (Model.TieneDescuento)
                        {
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-muted">Precio de Descuento</label>
                                <h4 class="text-success">@Model.PrecioDescuento?.ToString("C")</h4>
                                <small class="text-muted">
                                    Ahorro: @((Model.Precio - Model.PrecioDescuento.GetValueOrDefault()).ToString("C"))
                                    (@((100 - (Model.PrecioDescuento.GetValueOrDefault() / Model.Precio * 100)).ToString("0.00"))%)
                                </small>
                            </div>

                            <div class="col-12">
                                <div class="alert alert-success" role="alert">
                                    <i class="fas fa-percentage me-2"></i>
                                    <strong>¡Este producto está en oferta!</strong>
                                    <span class="badge bg-danger ms-2">OFERTA ESPECIAL</span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-muted">Precio Final</label>
                                <h4>@Model.PrecioFinal.ToString("C")</h4>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Stock y alertas -->
            <div class="card vshop-card">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="fas fa-boxes me-2"></i>Gestión de Stock</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <div class="text-center p-3 rounded @(Model.Stock == 0 ? "bg-danger text-white" :
                                                                                               Model.Stock <= Model.StockMinimo ? "bg-warning text-dark" : "bg-success text-white")">
                                <div class="h1 mb-1">@Model.Stock</div>
                                <small>Unidades Disponibles</small>
                            </div>
                        </div>

                        <div class="col-md-8">
                            <div class="mb-3">
                                <label class="form-label text-muted">Estado del Inventario</label>
                                <div class="alert alert-@Model.EstadoStockClase" role="alert">
                                    <i class="fas fa-exclamation-circle me-2"></i>
                                    @switch (Model.EstadoStock)
                                    {
                                        case "Agotado":
                                            <strong>Producto agotado</strong>
                                            <p class="mb-0">No hay unidades disponibles para la venta.</p>
                                            break;
                                        case "Stock Bajo":
                                            <strong>Stock por debajo del mínimo</strong>
                                            <p class="mb-0">El stock actual (@Model.Stock) es menor que el stock mínimo establecido (@Model.StockMinimo).</p>
                                            break;
                                        default:
                                            <strong>Stock disponible</strong>
                                            <p class="mb-0">Hay suficiente inventario para las ventas.</p>
                                            break;
                                    }
                                </div>
                            </div>

                            @if (Model.Stock <= Model.StockMinimo && Model.Stock > 0)
                            {
                                <div class="alert alert-warning" role="alert">
                                    <i class="fas fa-exclamation-triangle me-2"></i>
                                    <strong>Atención:</strong> El stock está por debajo del mínimo establecido.
                                    Considera realizar un nuevo pedido.
                                </div>
                            }
                            else if (Model.Stock == 0)
                            {
                                <div class="alert alert-danger" role="alert">
                                    <i class="fas fa-ban me-2"></i>
                                    <strong>Producto agotado:</strong> No se puede vender hasta que se reponga el stock.
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Imágenes adicionales -->
    @if (Model.Imagenes != null && Model.Imagenes.Count > 0)
    {
        <div class="row mt-4">
            <div class="col-12">
                <div class="card vshop-card">
                    <div class="card-header bg-light d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="fas fa-images me-2"></i>Galería de Imágenes</h5>
                        <span class="badge bg-vshop-gradient">@Model.Imagenes.Count imágenes</span>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            @foreach (var imagen in Model.Imagenes.OrderBy(i => i.Orden))
                            {
                                <div class="col-md-3 col-sm-4 col-6">
                                    <div class="card border-0 shadow-sm">
                                        <img src="@Url.Content($"~/{imagen.UrlImagen}")"
                                             class="card-img-top"
                                             alt="Imagen @imagen.Orden"
                                             style="height: 200px; object-fit: cover; cursor: pointer;"
                                             onclick="openImageModal('@Url.Content($"~/{imagen.UrlImagen}")')">
                                        <div class="card-body text-center">
                                            <small class="text-muted">Orden: @imagen.Orden</small>
                                            @if (imagen.EsPrincipal)
                                            {
                                                <span class="badge bg-primary ms-1">Principal</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Modal para vista ampliada de imágenes -->
<div class="modal fade" id="imageModal" tabindex="-1" aria-labelledby="imageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="imageModalLabel">Vista Ampliada</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <img id="modalImage" src="" class="img-fluid" alt="Imagen ampliada">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function changeMainImage(imageUrl, element) {
            // Cambiar la imagen principal
            document.getElementById('mainImage').src = imageUrl;

            // Remover borde de todas las miniaturas
            document.querySelectorAll('.img-thumbnail').forEach(img => {
                img.classList.remove('border-primary');
            });

            // Agregar borde a la miniatura seleccionada
            element.classList.add('border-primary');
        }

        function openImageModal(imageUrl) {
            document.getElementById('modalImage').src = imageUrl;
            var imageModal = new bootstrap.Modal(document.getElementById('imageModal'));
            imageModal.show();
        }

        // Inicializar tooltips
        $(document).ready(function() {
            $('[data-bs-toggle="tooltip"]').tooltip();

            // Formatear números con separadores
            $('.stock-number').each(function() {
                var number = parseInt($(this).text());
                $(this).text(number.toLocaleString());
            });
        });
    </script>
}