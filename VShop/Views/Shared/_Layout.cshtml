<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VShop</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VShop.styles.css" asp-append-version="true" />
</head>
<body>
    <!-- Barra de navegación horizontal -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">VShop</a>

            <!-- Botón para menú responsive -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Elementos del menú -->
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link text-dark @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Productos" ? "active fw-bold" : "")"
                           asp-controller="Productos" asp-action="Index">
                            <i class="fas fa-box me-1"></i>Productos
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Categorias" ? "active fw-bold" : "")"
                           asp-controller="Categorias" asp-action="Index">
                            <i class="fas fa-tags me-1"></i>Categorías
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Marcas" ? "active fw-bold" : "")"
                           asp-controller="Marcas" asp-action="Index">
                            <i class="fas fa-trademark me-1"></i>Marcas
                        </a>
                    </li>
                </ul>

                <!-- Espacio para elementos adicionales a la derecha (opcional) -->
                <div class="d-flex">
                    <!-- Puedes agregar aquí elementos como buscador, notificaciones, perfil de usuario, etc. -->
                    <!-- Ejemplo: -->
                    <!--
                    <div class="input-group me-3" style="max-width: 300px;">
                        <input type="text" class="form-control" placeholder="Buscar..." aria-label="Buscar">
                        <button class="btn btn-outline-secondary" type="button">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                    -->
                </div>
            </div>
        </div>
    </nav>

    <!-- Contenido principal -->
    <div class="container-fluid">
        <main role="main" class="pb-3 pt-4">
            <partial name="_AlertsPartial" />
            @RenderBody()
        </main>

        <footer class="border-top footer text-muted mt-5">
            <div class="container py-3">
                <div class="row">
                    <div class="col-md-12 text-center">
                        &copy; @DateTime.Now.Year - VShop
                    </div>
                </div>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/Moneda.js" asp-append-version="true"></script>
    <script src="~/js/Moneda-opcional.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>