<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VShop</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <link rel="stylesheet" href="~/css/cliente.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VShop.styles.css" asp-append-version="true" />
    <style>
        :root {
            --primary-color: #667eea;
            --secondary-color: #764ba2;
            --accent-color: #f56565;
            --light-color: #f8f9fa;
            --dark-color: #2d3748;
            --gray-color: #718096;
        }

        .bg-primary-gradient {
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%) !important;
        }

        .text-primary-gradient {
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .btn-primary-gradient {
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
            border: none;
            color: white;
            transition: all 0.3s ease;
        }

            .btn-primary-gradient:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
                color: white;
            }

        .btn-outline-primary-gradient {
            border: 2px solid transparent;
            background: linear-gradient(white, white) padding-box, linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%) border-box;
            color: var(--primary-color);
            transition: all 0.3s ease;
        }

            .btn-outline-primary-gradient:hover {
                background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
                color: white;
            }
    </style>
</head>
<body>
    <!-- Header -->
    <header class="sticky-top bg-white shadow-sm">
        <!-- Top Bar -->
        <div class="bg-dark text-white py-2">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <small>
                            <i class="fas fa-truck me-1"></i> Envío gratis en compras mayores a $500
                        </small>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <small>
                            <i class="fas fa-phone me-1"></i> Soporte: (123) 456-7890
                        </small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Navigation -->
        <nav class="navbar navbar-expand-lg navbar-light py-3">
            <div class="container">
                <!-- Logo -->
                <a class="navbar-brand fw-bold fs-3" asp-controller="Client" asp-action="Index">
                    <span class="text-primary-gradient">V</span>Shop
                </a>

                <!-- Search Bar -->
                <div class="mx-lg-4 flex-grow-1">
                    <form asp-controller="Client" asp-action="Index" method="get" class="position-relative">
                        <div class="input-group">
                            <input type="text"
                                   class="form-control border-end-0"
                                   name="Busqueda"
                                   placeholder="Buscar productos..."
                                   value="@Context.Request.Query["Busqueda"]">
                            <button class="btn btn-primary-gradient border-start-0" type="submit">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </form>
                </div>

                <!-- User Actions -->
                <div class="d-flex align-items-center">
                    <!-- Wishlist -->
                    <a href="#" class="text-dark me-4 position-relative">
                        <i class="fas fa-heart fa-lg"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                            0
                        </span>
                    </a>

                    <!-- Cart -->
                    <a href="#" class="text-dark me-4 position-relative" data-bs-toggle="offcanvas" data-bs-target="#cartOffcanvas">
                        <i class="fas fa-shopping-cart fa-lg"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary">
                            0
                        </span>
                    </a>

                    <!-- User Dropdown -->
                    <div class="dropdown">
                        <a href="#" class="text-dark text-decoration-none dropdown-toggle"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fas fa-user-circle fa-lg"></i>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="#"><i class="fas fa-user me-2"></i>Mi Perfil</a></li>
                            <li><a class="dropdown-item" href="#"><i class="fas fa-shopping-bag me-2"></i>Mis Pedidos</a></li>
                            <li><a class="dropdown-item" href="#"><i class="fas fa-heart me-2"></i>Lista de Deseos</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" asp-controller="Login" asp-action="Logout"><i class="fas fa-sign-out-alt me-2"></i>Cerrar Sesión</a></li>
                        </ul>
                    </div>

                    <!-- Mobile Menu Toggle -->
                    <button class="navbar-toggler ms-3" type="button" data-bs-toggle="collapse"
                            data-bs-target="#navbarNav" aria-controls="navbarNav"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                </div>
            </div>
        </nav>

        <!-- Category Navigation -->
        <div class="border-top">
            <div class="container">
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Catalogo" ? "active fw-bold" : "")"
                               asp-controller="Client" asp-action="Index">
                                <i class="fas fa-home me-1"></i>Inicio
                            </a>
                        </li>
                        <!-- Las categorías se cargarán dinámicamente -->
                        @if (ViewBag.Categorias != null)
                        {
                            @foreach (var categoria in ViewBag.Categorias as List<CategoriaViewModel>)
                            {
                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="Client"
                                       asp-action="Index"
                                       asp-route-CategoriaId="@categoria.Id">
                                        @categoria.Nombre
                                    </a>
                                </li>
                            }
                        }
                        <li class="nav-item">
                            <a class="nav-link text-danger" href="#">
                                <i class="fas fa-fire me-1"></i>Ofertas
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-success" href="#">
                                <i class="fas fa-leaf me-1"></i>Nuevos
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main role="main">
        <!-- Notifications -->
        <div id="notification-container" class="position-fixed top-0 end-0 p-3" style="z-index: 1050;"></div>

        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-dark text-white pt-5 pb-4 mt-5">
        <div class="container">
            <div class="row">
                <!-- About -->
                <div class="col-lg-4 col-md-6 mb-4">
                    <h5 class="fw-bold mb-3">VShop</h5>
                    <p class="text-light">
                        Tu tienda en línea de confianza. Ofrecemos productos de calidad con la mejor experiencia de compra.
                    </p>
                    <div class="d-flex gap-3 mt-4">
                        <a href="#" class="text-white"><i class="fab fa-facebook fa-lg"></i></a>
                        <a href="#" class="text-white"><i class="fab fa-twitter fa-lg"></i></a>
                        <a href="#" class="text-white"><i class="fab fa-instagram fa-lg"></i></a>
                        <a href="#" class="text-white"><i class="fab fa-tiktok fa-lg"></i></a>
                    </div>
                </div>

                <!-- Quick Links -->
                <div class="col-lg-2 col-md-6 mb-4">
                    <h6 class="fw-bold mb-3">Enlaces Rápidos</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="#" class="text-light text-decoration-none">Inicio</a></li>
                        <li class="mb-2"><a href="#" class="text-light text-decoration-none">Productos</a></li>
                        <li class="mb-2"><a href="#" class="text-light text-decoration-none">Categorías</a></li>
                        <li class="mb-2"><a href="#" class="text-light text-decoration-none">Ofertas</a></li>
                        <li><a href="#" class="text-light text-decoration-none">Nuevos</a></li>
                    </ul>
                </div>

                <!-- Categories -->
                <div class="col-lg-3 col-md-6 mb-4">
                    <h6 class="fw-bold mb-3">Categorías</h6>
                    <ul class="list-unstyled">
                        @if (ViewBag.Categorias != null)
                        {
                            @foreach (var categoria in (ViewBag.Categorias as List<CategoriaViewModel>).Take(5))
                            {
                                <li class="mb-2">
                                    <a asp-controller="Client"
                                       asp-action="Index"
                                       asp-route-CategoriaId="@categoria.Id"
                                       class="text-light text-decoration-none">
                                        @categoria.Nombre
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                </div>

                <!-- Contact -->
                <div class="col-lg-3 col-md-6 mb-4">
                    <h6 class="fw-bold mb-3">Contacto</h6>
                    <ul class="list-unstyled text-light">
                        <li class="mb-2"><i class="fas fa-map-marker-alt me-2"></i> Ciudad, País</li>
                        <li class="mb-2"><i class="fas fa-phone me-2"></i> (123) 456-7890</li>
                        <li class="mb-2"><i class="fas fa-envelope me-2"></i> info@vshop.com</li>
                        <li><i class="fas fa-clock me-2"></i> Lun - Vie: 9am - 6pm</li>
                    </ul>
                </div>
            </div>

            <hr class="bg-light my-4">

            <div class="row align-items-center">
                <div class="col-md-6">
                    <p class="mb-0">&copy; @DateTime.Now.Year VShop. Todos los derechos reservados.</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <img src="~/images/payment-methods.png" alt="Métodos de pago" class="img-fluid" style="max-height: 40px;">
                </div>
            </div>
        </div>
    </footer>

    <!-- Offcanvas Cart -->
    <div class="offcanvas offcanvas-end" tabindex="-1" id="cartOffcanvas" aria-labelledby="cartOffcanvasLabel">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title" id="cartOffcanvasLabel">
                <i class="fas fa-shopping-cart me-2"></i>Mi Carrito
            </h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">
            <div id="cartItems" class="mb-3">
                <div class="text-center py-5">
                    <i class="fas fa-shopping-cart fa-3x text-muted mb-3"></i>
                    <p class="text-muted">Tu carrito está vacío</p>
                </div>
            </div>
            <div class="border-top pt-3">
                <div class="d-flex justify-content-between mb-2">
                    <span>Subtotal:</span>
                    <span class="fw-bold">$0.00</span>
                </div>
                <div class="d-flex justify-content-between mb-3">
                    <span>Envío:</span>
                    <span class="text-success">Gratis</span>
                </div>
                <div class="d-flex justify-content-between mb-3">
                    <span class="fw-bold">Total:</span>
                    <span class="fw-bold fs-5">$0.00</span>
                </div>
                <div class="d-grid gap-2">
                    <a href="#" class="btn btn-primary-gradient">Ver Carrito</a>
                    <a href="#" class="btn btn-outline-primary-gradient">Finalizar Compra</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Back to Top Button -->
    <button id="backToTop" class="btn btn-primary-gradient rounded-circle position-fixed bottom-0 end-0 m-4"
            style="width: 50px; height: 50px; display: none;">
        <i class="fas fa-arrow-up"></i>
    </button>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/cliente.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function() {
            // Back to top button
            $(window).scroll(function() {
                if ($(this).scrollTop() > 300) {
                    $('#backToTop').fadeIn();
                } else {
                    $('#backToTop').fadeOut();
                }
            });

            $('#backToTop').click(function() {
                $('html, body').animate({ scrollTop: 0 }, 300);
                return false;
            });

            // Load categories dynamically if not already loaded
            if ($('#navbarNav .nav-item').length <= 5) {
                $.ajax({
                    url: '@Url.Action("GetCategoriasActivas", "Productos")',
                    type: 'GET',
                    success: function(categorias) {
                        var navbar = $('#navbarNav .navbar-nav');
                        // Add categories after Home link
                        categorias.forEach(function(categoria) {
                            var li = $('<li class="nav-item"></li>');
                            var a = $('<a class="nav-link"></a>')
                                .attr('href', '@Url.Action("Catalogo", "Productos")?CategoriaId=' + categoria.id)
                                .text(categoria.nombre);
                            li.append(a);
                            navbar.children(':nth-child(1)').after(li);
                        });
                    }
                });
            }

            // Initialize tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });

            // Cart functionality
            function updateCartCount(count) {
                $('.fa-shopping-cart').next('.badge').text(count);
            }

            // Example: Add to cart
            $('.btn-add-to-cart').click(function(e) {
                e.preventDefault();
                var productId = $(this).data('product-id');

                // AJAX call to add to cart
                $.ajax({
                    url: '@Url.Action("AddToCart", "Cart")',
                    type: 'POST',
                    data: { productId: productId, quantity: 1 },
                    success: function(response) {
                        if (response.success) {
                            updateCartCount(response.cartCount);
                            toastr.success('Producto agregado al carrito');
                        } else {
                            toastr.error('Error al agregar al carrito');
                        }
                    }
                });
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>