@model ProductosIndexViewModel
@{
    Layout = "_LayoutClient";
    ViewData["Title"] = "Catálogo de Productos";
    ViewData["ActivePage"] = "Catalogo";
}

<div class="container-fluid py-4">
    <!-- Hero Section -->
    <div class="bg-light py-5 mb-5">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <h1 class="display-5 fw-bold text-vshop">Catálogo de Productos</h1>
                    <p class="lead text-muted">Descubre nuestra amplia selección de productos</p>
                </div>
                <div class="col-lg-6">
                    <form asp-action="Index" method="get" class="d-flex">
                        <input type="text" class="form-control form-control-lg me-2"
                               name="Busqueda" value="@Model.Filtro.Busqueda"
                               placeholder="Buscar productos...">
                        <button type="submit" class="btn btn-vshop btn-lg">
                            <i class="fas fa-search"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="container">
        <div class="row">
            <!-- Sidebar de filtros -->
            <div class="col-lg-3 mb-4">
                <div class="card vshop-card sticky-top" style="top: 20px;">
                    <div class="card-header bg-vshop text-white">
                        <h5 class="mb-0"><i class="fas fa-filter me-2"></i>Filtros</h5>
                    </div>
                    <div class="card-body">
                        <form asp-action="Catalogo" method="get">
                            <!-- Buscador -->
                            <div class="mb-3">
                                <label asp-for="Filtro.Busqueda" class="form-label"></label>
                                <input asp-for="Filtro.Busqueda" class="form-control" placeholder="Nombre, descripción...">
                            </div>

                            <!-- Categoría -->
                            <div class="mb-3">
                                <label asp-for="Filtro.CategoriaId" class="form-label"></label>
                                <select asp-for="Filtro.CategoriaId" class="form-select">
                                    <option value="">Todas las categorías</option>
                                    @foreach (var categoria in Model.Categorias)
                                    {
                                        <option value="@categoria.Id" selected="@(Model.Filtro.CategoriaId == categoria.Id)">
                                            @categoria.Nombre
                                        </option>
                                    }
                                </select>
                            </div>

                            <!-- Marca -->
                            <div class="mb-3">
                                <label asp-for="Filtro.MarcaId" class="form-label"></label>
                                <select asp-for="Filtro.MarcaId" class="form-select">
                                    <option value="">Todas las marcas</option>
                                    @foreach (var marca in Model.Marcas)
                                    {
                                        <option value="@marca.Id" selected="@(Model.Filtro.MarcaId == marca.Id)">
                                            @marca.Nombre
                                        </option>
                                    }
                                </select>
                            </div>

                            <!-- Estado Stock -->
                            <div class="mb-3">
                                <label asp-for="Filtro.EstadoStock" class="form-label"></label>
                                <select asp-for="Filtro.EstadoStock" class="form-select">
                                    <option value="todos">Todos los estados</option>
                                    <option value="disponible" selected="@(Model.Filtro.EstadoStock == "disponible")">Disponible</option>
                                    <option value="bajo" selected="@(Model.Filtro.EstadoStock == "bajo")">Stock Bajo</option>
                                    <option value="agotado" selected="@(Model.Filtro.EstadoStock == "agotado")">Agotado</option>
                                </select>
                            </div>

                            <!-- Ordenar por -->
                            <div class="mb-3">
                                <label asp-for="Filtro.OrdenarPor" class="form-label"></label>
                                <select asp-for="Filtro.OrdenarPor" class="form-select">
                                    <option value="nombre" selected="@(Model.Filtro.OrdenarPor == "nombre")">Nombre (A-Z)</option>
                                    <option value="reciente" selected="@(Model.Filtro.OrdenarPor == "reciente")">Más recientes</option>
                                    <option value="precio_asc" selected="@(Model.Filtro.OrdenarPor == "precio_asc")">Precio (menor a mayor)</option>
                                    <option value="precio_desc" selected="@(Model.Filtro.OrdenarPor == "precio_desc")">Precio (mayor a menor)</option>
                                </select>
                            </div>

                            <!-- Solo con descuento -->
                            <div class="mb-3 form-check">
                                <input asp-for="Filtro.SoloConDescuento" class="form-check-input" />
                                <label asp-for="Filtro.SoloConDescuento" class="form-check-label"></label>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-vshop">
                                    <i class="fas fa-filter me-2"></i>Aplicar Filtros
                                </button>
                                <a asp-action="Catalogo" class="btn btn-outline-secondary">
                                    <i class="fas fa-redo me-2"></i>Limpiar Filtros
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Contenido principal -->
            <div class="col-lg-9">
                <!-- Información de resultados -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <p class="mb-0 text-muted">
                            Mostrando <strong>@Model.Productos.Count</strong> de <strong>@Model.Paginacion.TotalRegistros</strong> productos
                        </p>
                    </div>
                    <div class="d-flex align-items-center">
                        <span class="me-2 text-muted">Vista:</span>
                        <div class="btn-group" role="group">
                            <button type="button" class="btn btn-outline-secondary active" id="btnGridView">
                                <i class="fas fa-th"></i>
                            </button>
                            <button type="button" class="btn btn-outline-secondary" id="btnListView">
                                <i class="fas fa-list"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Vista de cuadrícula (por defecto) -->
                <div id="gridView">
                    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">
                        @foreach (var producto in Model.Productos)
                        {
                            <div class="col">
                                <div class="card h-100 product-card vshop-card hover-shadow">
                                    <!-- Badges -->
                                    <div class="product-badges position-absolute top-0 start-0 p-2">
                                        @if (producto.TieneDescuento)
                                        {
                                            <span class="badge bg-danger me-1">Oferta</span>
                                        }
                                        <span class="badge @producto.EstadoStockClase">@producto.EstadoStock</span>
                                    </div>

                                    <!-- Imagen -->
                                    <div class="product-image position-relative overflow-hidden">
                                        @if (!string.IsNullOrEmpty(producto.ImagenPrincipal))
                                        {
                                            <img src="~/@producto.ImagenPrincipal"
                                                 class="card-img-top"
                                                 alt="@producto.Nombre"
                                                 style="height: 250px; object-fit: cover;">
                                        }
                                        else
                                        {
                                            <div class="card-img-top bg-light d-flex align-items-center justify-content-center"
                                                 style="height: 250px;">
                                                <i class="fas fa-image fa-3x text-muted"></i>
                                            </div>
                                        }

                                        <!-- Overlay de acciones -->
                                        <div class="product-actions position-absolute w-100 bottom-0 start-0 p-3 bg-gradient">
                                            <div class="d-flex justify-content-center gap-2">
                                                <a asp-action="Details" asp-route-id="@producto.Id"
                                                   class="btn btn-vshop btn-sm">
                                                    <i class="fas fa-eye me-1"></i>Ver Detalles
                                                </a>
                                                <button class="btn btn-outline-vshop btn-sm"
                                                        title="Agregar a favoritos">
                                                    <i class="far fa-heart"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Contenido -->
                                    <div class="card-body">
                                        <div class="mb-2">
                                            @if (!string.IsNullOrEmpty(producto.Marca) && producto.Marca != "Sin marca")
                                            {
                                                <span class="badge bg-light text-dark small">@producto.Marca</span>
                                            }
                                            <span class="badge bg-light text-dark small">@producto.Categoria</span>
                                        </div>

                                        <h5 class="card-title">
                                            <a asp-action="Details" asp-route-id="@producto.Id"
                                               class="text-decoration-none text-dark">
                                                @producto.Nombre
                                            </a>
                                        </h5>

                                        <p class="card-text text-muted small">
                                            @if (producto.Descripcion?.Length > 100)
                                            {
                                                @producto.Descripcion.Substring(0, 100)
                                        
                                                <text>...</text>
                                            }
                                            else
                                            {
                                                @producto.Descripcion
                                            }
                                        </p>

                                        <div class="mt-3">
                                            <small class="text-muted">SKU: @producto.SKU</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Vista de lista (oculta por defecto) -->
                <div id="listView" class="d-none">
                    <div class="list-group">
                        @foreach (var producto in Model.Productos)
                        {
                            <div class="list-group-item list-group-item-action">
                                <div class="row align-items-center">
                                    <div class="col-md-3">
                                        @if (!string.IsNullOrEmpty(producto.ImagenPrincipal))
                                        {
                                            <img src="~/@producto.ImagenPrincipal"
                                                 class="img-fluid rounded"
                                                 alt="@producto.Nombre"
                                                 style="max-height: 150px;">
                                        }
                                        else
                                        {
                                            <div class="bg-light d-flex align-items-center justify-content-center rounded"
                                                 style="height: 150px;">
                                                <i class="fas fa-image fa-2x text-muted"></i>
                                            </div>
                                        }
                                    </div>
                                    <div class="col-md-6">
                                        <h5 class="mb-1">
                                            <a asp-action="Details" asp-route-id="@producto.Id"
                                               class="text-decoration-none text-dark">
                                                @producto.Nombre
                                            </a>
                                        </h5>
                                        <p class="mb-2 text-muted small">@producto.Descripcion</p>
                                        <div class="mb-2">
                                            @if (!string.IsNullOrEmpty(producto.Marca) && producto.Marca != "Sin marca")
                                            {
                                                <span class="badge bg-light text-dark small me-1">@producto.Marca</span>
                                            }
                                            <span class="badge bg-light text-dark small me-1">@producto.Categoria</span>
                                            <span class="badge @producto.EstadoStockClase small">@producto.EstadoStock</span>
                                        </div>
                                        <small class="text-muted">SKU: @producto.SKU</small>
                                    </div>
                                    <div class="col-md-3 text-end">
                                        <a asp-action="Details" asp-route-id="@producto.Id"
                                           class="btn btn-vshop">
                                            Ver Detalles
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Paginación -->
                @if (Model.Paginacion.TotalPaginas > 1)
                {
                    <nav aria-label="Paginación" class="mt-5">
                        <ul class="pagination justify-content-center">
                            @if (Model.Paginacion.PaginaActual > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link"
                                       asp-action="Catalogo"
                                       asp-route-pagina="@(Model.Paginacion.PaginaActual - 1)"
                                       asp-route-Busqueda="@Model.Filtro.Busqueda"
                                       asp-route-CategoriaId="@Model.Filtro.CategoriaId"
                                       asp-route-MarcaId="@Model.Filtro.MarcaId"
                                       asp-route-EstadoStock="@Model.Filtro.EstadoStock"
                                       asp-route-OrdenarPor="@Model.Filtro.OrdenarPor"
                                       asp-route-SoloConDescuento="@Model.Filtro.SoloConDescuento">
                                        <i class="fas fa-chevron-left"></i>
                                    </a>
                                </li>
                            }

                            @for (int i = 1; i <= Model.Paginacion.TotalPaginas; i++)
                            {
                                if (i == Model.Paginacion.PaginaActual)
                                {
                                    <li class="page-item active">
                                        <span class="page-link">@i</span>
                                    </li>
                                }
                                else
                                {
                                    <li class="page-item">
                                        <a class="page-link"
                                           asp-action="Catalogo"
                                           asp-route-pagina="@i"
                                           asp-route-Busqueda="@Model.Filtro.Busqueda"
                                           asp-route-CategoriaId="@Model.Filtro.CategoriaId"
                                           asp-route-MarcaId="@Model.Filtro.MarcaId"
                                           asp-route-EstadoStock="@Model.Filtro.EstadoStock"
                                           asp-route-OrdenarPor="@Model.Filtro.OrdenarPor"
                                           asp-route-SoloConDescuento="@Model.Filtro.SoloConDescuento">
                                            @i
                                        </a>
                                    </li>
                                }
                            }

                            @if (Model.Paginacion.PaginaActual < Model.Paginacion.TotalPaginas)
                            {
                                <li class="page-item">
                                    <a class="page-link"
                                       asp-action="Catalogo"
                                       asp-route-pagina="@(Model.Paginacion.PaginaActual + 1)"
                                       asp-route-Busqueda="@Model.Filtro.Busqueda"
                                       asp-route-CategoriaId="@Model.Filtro.CategoriaId"
                                       asp-route-MarcaId="@Model.Filtro.MarcaId"
                                       asp-route-EstadoStock="@Model.Filtro.EstadoStock"
                                       asp-route-OrdenarPor="@Model.Filtro.OrdenarPor"
                                       asp-route-SoloConDescuento="@Model.Filtro.SoloConDescuento">
                                        <i class="fas fa-chevron-right"></i>
                                    </a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Alternar entre vista de cuadrícula y lista
            $('#btnGridView').click(function() {
                $(this).addClass('active');
                $('#btnListView').removeClass('active');
                $('#gridView').removeClass('d-none');
                $('#listView').addClass('d-none');
            });

            $('#btnListView').click(function() {
                $(this).addClass('active');
                $('#btnGridView').removeClass('active');
                $('#listView').removeClass('d-none');
                $('#gridView').addClass('d-none');
            });
        });
    </script>
}